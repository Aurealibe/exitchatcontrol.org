---
import Base from '../layouts/Base.astro'
import { defaultLocale, localeNames, localePath, locales } from '../i18n/config'
---

<Base locale={defaultLocale}>
  <main id="content" class="wrap py-16 text-center">
    <p class="eyebrow">404</p>
    <h1 class="text-2xl">This page does not exist.</h1>
    <p class="text-dim">The guide, in full, lives here:</p>
    <p class="font-mono">
      {
        locales.map((l) => (
          <a href={`${localePath(l)}/`.replace('//', '/')} class="mx-2">
            {localeNames[l]}
          </a>
        ))
      }
    </p>
  </main>
</Base>
